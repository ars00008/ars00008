<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="420.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.MatchingGame.controller.SaveSlotsController">

    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="16.0"/>
            </padding>
            <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Save Slots"/>
            <Label fx:id="infoLabel" text=""/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Slot 1 (placeholder)"/>
            <HBox alignment="CENTER" spacing="10">
                <Button text="Save" disable="true"/>
                <Button text="Load" disable="true"/>
            </HBox>
            <Label text="(Buttons will be enabled for registered users when save/load is implemented.)"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0"/>
            </padding>
            <Button text="Back" onAction="#handleBack"/>
        </HBox>
    </bottom>

</BorderPane>

