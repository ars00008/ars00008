<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="420.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.MatchingGame.controller.RanksController">

    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="16.0"/>
            </padding>
            <Text style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Ranks"/>
            <Label text="Ranking list (placeholder)."/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="8">
            <Label text="1. Alice - 1200"/>
            <Label text="2. Bob - 980"/>
            <Label text="3. Carol - 760"/>
            <Label text="(Later: load from local storage and sort by score.)"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0"/>
            </padding>
            <Button text="Back" onAction="#handleBack"/>
        </HBox>
    </bottom>

</BorderPane>

