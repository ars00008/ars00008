<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="500.0" prefWidth="760.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.MatchingGame.controller.MainMenuController">

    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="16.0"/>
            </padding>
            <Text style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Main Menu"/>
            <HBox spacing="10">
                <Label text="User:"/>
                <Label fx:id="userLabel" text="(unknown)"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="14.0">
            <Button text="Start Easy (two 4×4 grids)" onAction="#handleStartEasy" prefWidth="260"/>
            <Button text="Start Hard (10×10 grid)" onAction="#handleStartHard" prefWidth="260"/>
            <Separator prefWidth="320"/>
            <Button fx:id="saveSlotsButton" text="Save Slots" onAction="#handleOpenSaveSlots" prefWidth="260"/>
            <Button text="Ranks" onAction="#handleOpenRanks" prefWidth="260"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0"/>
            </padding>
            <Button text="Logout" onAction="#handleLogout"/>
            <Button text="Exit" onAction="#handleExit"/>
        </HBox>
    </bottom>

</BorderPane>

